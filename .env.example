# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Notion internal integration token (secret_...)
NOTION_TOKEN=

# Notion database ID (UUID, no dashes required)
NOTION_DATABASE_ID=

# Optional: faster-whisper defaults for voice notes
# WHISPER_LANGUAGE=fr
# WHISPER_MODEL_SIZE=base

# Optional: OpenRouter (interprets messages for Notion Title, Label, Type, URL, Description, Interest)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=telegram-to-notion
